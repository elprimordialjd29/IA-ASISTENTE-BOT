# ============================================
# VANEGAS - Variables de Entorno
# Copia como .env y completa los valores
# ============================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Web App ---
PORT=8000
HOST=0.0.0.0
# Contraseña para acceder a la web de VANEGAS
VANEGAS_PASSWORD=cambia_esta_clave

# --- Telegram (solo alertas proactivas) ---
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_CHAT_ID=123456789

# --- Gmail OAuth2 ---
GMAIL_CREDENTIALS_PATH=data/gmail_credentials.json
GMAIL_TOKEN_PATH=data/gmail_token.json

# --- Bots a Monitorear ---
BOT_PERFUMERIA_PATH=../perfumeria-bot
BOT_PERFUMERIA_NAME=Chu (Perfumería)
BOT_PERFUMERIA_SCRIPT=bot.js

BOT_SALUD_PATH=../bot-salud
BOT_SALUD_NAME=Bot Salud
BOT_SALUD_SCRIPT=index.js

# --- Intervalos de monitoreo (minutos) ---
EMAIL_CHECK_INTERVAL=15
BOT_CHECK_INTERVAL=10
TOKEN_ALERT_THRESHOLD_DAILY=1000000
TIMEZONE=America/Bogota
